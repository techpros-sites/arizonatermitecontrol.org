---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Arizona's most trusted termite control experts. Free inspections, professional treatments, guaranteed results." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  </head>
  <body class="antialiased overflow-x-hidden">
    <!-- Navigation -->
    <header class="navbar">
      <div class="container">
        <a href="/" class="navbar-brand">
          <div class="logo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <div class="brand-text">
            <span class="brand-title">Arizona</span>
            <span class="brand-subtitle">Termite Control</span>
          </div>
        </a>

        <nav class="navbar-nav">
          <a href="#services">Services</a>
          <a href="#about">About</a>
          <a href="#contact" class="btn btn-primary">Free Inspection</a>
        </nav>
      </div>
    </header>

    <slot />

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <div class="footer-brand">
              <div class="footer-brand-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <span class="footer-brand-title">Arizona Termite Control</span>
            </div>
            <p class="footer-text">Protecting Arizona homes from termite damage since 2006. Professional inspections, treatments, and prevention services.</p>
          </div>

          <div>
            <h4 class="footer-title">Contact</h4>
            <ul class="footer-list">
              <li>(480) 660-3093</li>
              <li>9345 East Osage Avenue<br>Mesa, AZ 85212</li>
              <li>Mon-Fri: 9:00 AM - 5:00 PM</li>
            </ul>
          </div>

          <div>
            <h4 class="footer-title">Service Areas</h4>
            <div class="footer-areas">
              <span>Mesa</span>
              <span>Gilbert</span>
              <span>Chandler</span>
              <span>Tempe</span>
              <span>Queen Creek</span>
              <span>San Tan Valley</span>
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          <p class="footer-copyright">© 2026 Arizona Termite Control Company. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
