---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Arizona Termite Control | Professional Termite Services in Mesa & East Valley">
  
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg"></div>
    
    <div class="hero-blur">
      <div class="hero-blur-1"></div>
      <div class="hero-blur-2"></div>
    </div>
    
    <div class="grain-overlay"></div>
    
    <div class="container hero-content">
      <div class="max-w-3xl">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          <span class="hero-badge-text">Free Inspections Available</span>
        </div>
        
        <h1 class="hero-title text-balance">
          Protecting Arizona Homes
          <span>From Termites</span>
        </h1>
        
        <p class="hero-subtitle">
          Mesa & East Valley's most trusted termite control experts. Professional inspections, guaranteed treatments, and prevention that works.
        </p>
        
        <div class="hero-buttons">
          <a href="#contact" class="btn btn-primary">
            Get Free Inspection
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          
          <a href="tel:480-660-3093" class="btn btn-secondary">
            (480) 660-3093
          </a>
        </div>
        
        <div class="hero-stats">
          <div class="hero-stat">
            <p class="hero-stat-number">20+</p>
            <p class="hero-stat-label">Years Experience</p>
          </div>
          
          <div class="hero-stat-divider"></div>
          
          <div class="hero-stat">
            <p class="hero-stat-number">10K+</p>
            <p class="hero-stat-label">Homes Protected</p>
          </div>
          
          <div class="hero-stat-divider"></div>
          
          <div class="hero-stat">
            <p class="hero-stat-number">100%</p>
            <p class="hero-stat-label">Guaranteed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="section-padding bg-white">
    <div class="container">
      
      <div class="section-header">
        <span class="section-label">Our Services</span>
        <h2 class="section-title">Comprehensive Termite Solutions</h2>
        <p class="section-description">From inspection to prevention, we handle every aspect of termite control with precision and care.</p>
      </div>
      
      <div class="services-grid">
        <!-- Inspection -->
        <div class="service-card">
          <div class="service-icon" style="background-color: var(--color-terracotta)">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          
          <h3 class="service-title">Termite Inspections</h3>
          
          <p class="service-description">Thorough property examinations to detect termite presence. Our certified technicians identify early signs before damage spreads.</p>
          
          <ul class="service-list">
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Free on-site inspection</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Detailed written report</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Same-day results</span>
            </li>
          </ul>
        </div>
        
        <!-- Treatment -->
        <div class="service-card">
          <div class="service-icon" style="background-color: var(--color-copper)">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          
          <h3 class="service-title">Termite Treatments</h3>
          
          <p class="service-description">Professional elimination using chemical barriers, baiting systems, and targeted treatments. We eliminate colonies completely.</p>
          
          <ul class="service-list">
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Liquid barrier treatments</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Baiting systems</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Guaranteed elimination</span>
            </li>
          </ul>
        </div>
        
        <!-- Prevention -->
        <div class="service-card">
          <div class="service-icon" style="background-color: var(--color-sage-dark)">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          
          <h3 class="service-title">Prevention</h3>
          
          <p class="service-description">Proactive strategies to keep termites away. Prevention is always more cost-effective than repair.</p>
          
          <ul class="service-list">
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Annual inspections</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Moisture control</span>
            </li>
            <li>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Protective barriers</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section-padding about-section">
    <div class="grain-overlay"></div>
    
    <div class="container relative">
      <div class="about-grid">
        <div class="about-content">
          <span class="about-label">Why Choose Us</span>
          
          <h2 class="about-title">Arizona's Termite Specialists</h2>
          
          <p class="about-text">Unlike general pest control companies, we focus exclusively on termites. This specialization means better results for your home and complete elimination of the problem.</p>
          
          <div class="about-features">
            <div class="about-feature">
              <div class="about-feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h4 class="about-feature-title">Specialized Expertise</h4>
                <p class="about-feature-text">Termites are all we do. We know how to eliminate them correctly.</p>
              </div>
            </div>
            
            <div class="about-feature">
              <div class="about-feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h4 class="about-feature-title">East Valley Experts</h4>
                <p class="about-feature-text">We understand Arizona termites and the unique challenges of desert climates.</p>
              </div>
            </div>
            
            <div class="about-feature">
              <div class="about-feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h4 class="about-feature-title">20+ Years Experience</h4>
                <p class="about-feature-text">Over a decade of protecting Arizona homes from termite damage.</p>
              </div>
            </div>
          </div>
        </div>
        
        <div>
          <div class="stats-card">
            <div class="stats-card-border"></div>
            
            <div class="stats-list">
              <div class="stat-item">
                <p class="stat-number">10,000+</p>
                <p class="stat-label">Homes Protected</p>
              </div>
              
              <div class="stat-item">
                <p class="stat-number">7+</p>
                <p class="stat-label">Cities Served</p>
              </div>
              
              <div class="stat-item">
                <p class="stat-number">100%</p>
                <p class="stat-label">Satisfaction Guaranteed</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section id="contact" class="section-padding contact-section">
    <div class="contact-bg">
      <div class="contact-bg-circle-1"></div>
      <div class="contact-bg-circle-2"></div>
    </div>
    
    <div class="container contact-content">
      <span class="contact-label">Get Started Today</span>
      
      <h2 class="contact-title">Ready to Protect Your Home?</h2>
      
      <p class="contact-text">Don't wait until it's too late. Schedule your free termite inspection today and get peace of mind knowing your home is protected.</p>
      
      <div class="contact-buttons">
        <a href="tel:480-660-3093" class="contact-btn-white">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call (480) 660-3093
        </a>
        
        <a href="#" class="contact-btn-outline">
          Schedule Free Inspection
        </a>
      </div>
      
      <p class="contact-subtext">Serving Mesa, Gilbert, Chandler, Tempe & surrounding areas</p>
    </div>
  </section>

</Layout>
